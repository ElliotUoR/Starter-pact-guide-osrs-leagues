        "type": "info",
        "links": [
          {
            "text": "Arcuani's Archery Supplies",
            "url": "https://oldschool.runescape.wiki/w/Arcuani%27s_Archery_Supplies"
          }
        ]
      },
      {
        "id": "s1-traps",
        "text": "You can get birdsnares and box traps from Fortis General Store or the Hunter Guild (requires 46 Hunter) - Buy 3 bird snares and 5 box traps",
        "type": "info",
        "links": [
          {
            "text": "Fortis General Store",
            "url": "https://oldschool.runescape.wiki/w/Fortis_General_Store"
          },
          {
            "text": "Hunter Guild",
            "url": "https://oldschool.runescape.wiki/w/Hunter_Guild"
          }
        ]
      },
      {
        "id": "edit-1776122642955-vzx7o",
        "text": "Get 45 Fletching for 3-tick Hunting with box traps (Optional)",
        "type": "step"
      },
      {
        "id": "s1-fletch45modal",
        "text": "Click here for lvl 45 fletching guide",
        "type": "info",
        "modal": "fletching-45"
      },
      {
        "id": "edit-1776122704848-cvo75",
        "text": "With a knife and teak log (and 45 fletching) you can 3-tick hunt",
        "type": "info"
      },
      {
        "id": "s1-nounlock",
        "text": "DO NOT UNLOCK ANY OTHER REGIONS UNTIL COMPLETING HUNTER",
        "type": "warning"
      },
